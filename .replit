modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "artifacts/gol-da-sorte: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/gol-da-sorte"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/gol-da-sorte run dev"
cwd = "./artifacts/gol-da-sorte"
waitForPort = 24365
router = "path"

[workflows.workflow.tasks.env]
PORT = "24365"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 24365
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_URL = "https://93bfb1ea-adc9-4d86-bb85-20a1db235783-00-19ali1gz2i4qi.worf.replit.dev"
